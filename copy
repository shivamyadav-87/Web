<style>

.shop {
  position: relative;
}

/* Button */
.shop-btn {
  background: #2d5c4d;
  color: white;
  padding: 10px 20px;
  border: none;
  cursor: pointer;
}

/* 🔥 FULL WIDTH MEGA MENU */
.shop-mega {
  position: absolute;
  top: 120%;
  right: 0;

  width: 600px; /* tu 100vw bhi kar sakta hai */
  background: white;

  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;

  padding: 25px;
  box-shadow: 0 5px 20px rgba(0,0,0,0.15);

  opacity: 0;
  visibility: hidden;
  transform: translateY(10px);
  transition: 0.3s;
}

/* Items */
.item {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
}

.item img {
  width: 40px;
}

/* Hover */
.item:hover {
  background: #f5f5f5;
  padding: 5px;
  border-radius: 5px;
}

/* 🔥 SHOW ON HOVER */
.shop:hover .shop-mega {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}








/* Basic styling */
.menu {
  list-style: none;
}

.dropdown {
  position: relative;
  display: inline-block;
  padding: 10px 15px;
  cursor: pointer;
}

/* Hidden by default */
.dropdown-menu {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  background: white;
  width: 250px;
  box-shadow: 0 5px 10px rgba(0,0,0,0.1);
}

.dropdown-menu li {
  padding: 10px;
  border-bottom: 1px solid #eee;
}

/* 🔥 Hover pe show hoga */
.dropdown:hover .dropdown-menu {
  display: block;
}



.dropdown-menu {
  opacity: 0;
  visibility: hidden;
  transition: 0.3s;
}

.dropdown:hover .dropdown-menu {
  opacity: 1;
  visibility: visible;
}



.dock{
  display:flex;
  gap:15px;
  padding:7px;
  justify-content:center;
}

.icon{
  width:40px;
  transition:0.3s;
}

.icon img{
  width:100%;
  border-radius:15px;
}

.icon:hover{
  transform:scale(1.6);
}

.dock:hover .icon:not(:hover){
  transform:scale(0.9);
}


